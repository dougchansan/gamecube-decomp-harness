{
  "id": "ssbm_data_sheet",
  "kind": "csv_corpus",
  "title": "SSBM data sheet",
  "trust_tier": "external_hint",
  "freshness": "refreshable",
  "section": "code_context",
  "access_modes": [
    "source_search",
    "address_lookup",
    "offset_lookup",
    "graph_search"
  ],
  "description": "Codebase-derived function/symbol/reference facts plus legacy workbook and CSV exports for addresses, IDs, offsets, and row context.",
  "data_paths": [
    "projects/melee/knowledge/sources/code_context/ssbm_data_sheet/data"
  ],
  "index_outputs": [
    "projects/melee/knowledge/sources/code_context/ssbm_data_sheet/indexes/codebase_facts.jsonl",
    "projects/melee/knowledge/sources/code_context/ssbm_data_sheet/indexes/cells.jsonl"
  ],
  "commands": {
    "status": "python3 projects/melee/knowledge/sources/code_context/ssbm_data_sheet/api/status.py --json",
    "search": "python3 projects/melee/knowledge/sources/code_context/ssbm_data_sheet/api/search.py --query <query> --json",
    "lookup_address": "python3 projects/melee/knowledge/sources/code_context/ssbm_data_sheet/api/lookup_address.py --address <hex> --json",
    "lookup_offset": "python3 projects/melee/knowledge/sources/code_context/ssbm_data_sheet/api/lookup_offset.py --type <type> --offset <hex> --json",
    "build_codebase_facts": "python3 projects/melee/knowledge/sources/code_context/ssbm_data_sheet/commands/build_codebase_facts.py --repo-root <repo_root> --json",
    "check_freshness": "python3 projects/melee/knowledge/sources/code_context/ssbm_data_sheet/commands/build_codebase_facts.py --repo-root <repo_root> --check --json"
  },
  "capabilities": [
    "search",
    "lookup_address",
    "lookup_offset"
  ]
}
