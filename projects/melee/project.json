{
  "id": "melee",
  "displayName": "Super Smash Bros. Melee",
  "kind": "doldecomp-melee",
  "repoRoot": "./checkout",
  "stateDir": "./state",
  "graphDb": "./graph/graph.sqlite",
  "processName": "melee-live",
  "baseRef": "origin/master",
  "localEnv": "./local.env",
  "validation": {
    "qaTarget": "changes_all",
    "reportPath": "build/GALE01/report.json",
    "reportChangesPath": "build/GALE01/report_changes.json",
    "objdiffPath": "objdiff.json"
  },
  "dashboard": {
    "candidateLimit": 64,
    "queueTargetSize": 64,
    "queueLowWatermark": 16,
    "candidateWindow": 1024,
    "goalValue": 100
  },
  "pr": {
    "groupMode": "melee-subsystem",
    "titlePrefix": "Melee decomp",
    "branchPrefix": "decomp",
    "maxFilesPerPr": 8,
    "improvementMinGainPoints": 2.0,
    "improvementMinMatchedBytes": 64
  },
  "knowledge": {
    "globalSources": [
      "past_prs",
      "decomp_standards",
      "ssbm_data_sheet",
      "powerpc_docs",
      "external_mirrors",
      "path_facts"
    ],
    "projectSources": [
      "code_graph"
    ]
  }
}
