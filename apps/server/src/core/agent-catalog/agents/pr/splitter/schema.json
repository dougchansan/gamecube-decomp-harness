{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PR splitter plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "slices", "warnings", "rationale", "confidence"],
  "properties": {
    "schema_version": {
      "const": "colosseum_pr_splitter_plan_v1"
    },
    "slices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "display_name",
          "title",
          "lane",
          "scope",
          "files",
          "depends_on",
          "independence_kind",
          "review_focus",
          "pr_body_summary",
          "risks",
          "validation_notes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "lane": {
            "type": ["string", "null"],
            "enum": ["match", "local", null]
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "independence_kind": {
            "type": "string",
            "enum": ["independent", "shared-prep", "stacked", "needs-merge"]
          },
          "review_focus": {
            "type": "string"
          },
          "pr_body_summary": {
            "type": "string"
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "validation_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rationale": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
