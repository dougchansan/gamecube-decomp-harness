{
  "id": "path_facts",
  "kind": "document",
  "title": "Path-scoped Melee decomp facts",
  "trust_tier": "historical",
  "freshness": "snapshot",
  "description": "Curated path-scoped known wins for Melee decomp workers. Facts are compact hints with scope globs, provenance, stale checks, and explicit superseding evidence rules.",
  "data_paths": [
    "knowledge/sources/path_facts/data"
  ],
  "index_outputs": [
    "knowledge/sources/path_facts/indexes/path_facts.jsonl"
  ],
  "commands": {
    "status": "python3 knowledge/sources/path_facts/api/status.py --json",
    "search": "python3 knowledge/sources/path_facts/api/search.py --query <query> --limit 10 --json",
    "resolve_for_path": "python3 knowledge/sources/path_facts/api/resolve_for_path.py --path <source_path> --json",
    "proposals": "python3 knowledge/sources/path_facts/api/proposals.py --json"
  },
  "capabilities": [
    "search",
    "resolve_for_path",
    "proposal_listing",
    "scoped_worker_hints"
  ]
}
