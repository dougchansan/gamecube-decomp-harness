{
  "id": "past_prs",
  "kind": "pr_corpus",
  "title": "Past PR corpus",
  "trust_tier": "historical",
  "freshness": "refreshable",
  "section": "code_context",
  "access_modes": [
    "refreshable_corpus",
    "file_edges",
    "review_risks",
    "graph_search",
    "source_search"
  ],
  "description": "Historical PR dump, changed files, PR text, review comments, diffs, and generated postmortems.",
  "data_paths": [
    "knowledge/sources/code_context/past_prs/data"
  ],
  "index_outputs": [
    "knowledge/sources/code_context/past_prs/indexes/prs.jsonl",
    "knowledge/sources/code_context/past_prs/indexes/pr_file_edges.jsonl",
    "knowledge/sources/code_context/past_prs/indexes/file_rollups.jsonl"
  ],
  "commands": {
    "status": "python3 knowledge/sources/code_context/past_prs/api/status.py --json",
    "refresh": "bun run pr:refresh",
    "refresh_all": "bun run pr:refresh:all",
    "postmortems_32": "bun run pr:postmortems -- --jobs 32 --pending-only --complete-only --run-agent",
    "index": "bun run kg:rebuild -- --sources past_prs",
    "search": "python3 knowledge/sources/code_context/past_prs/api/search.py --query <query> --json",
    "graph_search": "bun run kg:search -- --source past_prs --query <query>"
  },
  "capabilities": [
    "search",
    "file_edges",
    "review_risks",
    "tactic_synthesis"
  ]
}
