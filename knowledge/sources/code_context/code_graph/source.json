{
  "id": "code_graph",
  "kind": "code_graph",
  "title": "Current checkout code graph",
  "trust_tier": "canonical",
  "freshness": "current_checkout",
  "section": "code_context",
  "access_modes": [
    "file_card",
    "rank_features",
    "editability",
    "graph_search"
  ],
  "description": "Current source files, units, functions, symbols, report status, and editability.",
  "data_paths": [
    "src",
    "include",
    "config/GALE01/symbols.txt",
    "config/GALE01/splits.txt",
    "objdiff.json",
    "build/GALE01/report.json"
  ],
  "index_outputs": [
    "knowledge/sources/code_context/code_graph/indexes/files.jsonl",
    "knowledge/sources/code_context/code_graph/indexes/functions.jsonl"
  ],
  "commands": {
    "status": "python3 knowledge/sources/code_context/code_graph/api/status.py --json",
    "search": "python3 knowledge/sources/code_context/code_graph/api/search.py --query <query> --json",
    "index": "bun run kg:rebuild -- --sources code_graph",
    "file_card": "bun run kg:file-card -- --source <source_path>",
    "rank_features": "bun run kg:rank-features"
  },
  "capabilities": [
    "file_card",
    "rank_features",
    "editability"
  ]
}
