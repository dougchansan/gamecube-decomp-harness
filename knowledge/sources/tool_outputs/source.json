{
  "id": "tool_outputs",
  "kind": "tool_output",
  "title": "Tool outputs",
  "trust_tier": "tool_evidence",
  "freshness": "generated",
  "description": "Normalized cached outputs from callable external tool integrations.",
  "data_paths": [
    "tools"
  ],
  "index_outputs": [
    "knowledge/sources/tool_outputs/indexes/tool_findings.jsonl"
  ],
  "commands": {
    "status": "python3 knowledge/sources/tool_outputs/api/status.py --json",
    "index_tools": "bun run kg:tool-indexes",
    "smoke": "bun run kg:smoke -- --strict",
    "search": "python3 knowledge/sources/tool_outputs/api/search.py --query <query> --json",
    "tool_lookup": "python3 knowledge/sources/tool_outputs/api/tool_lookup.py --tool <id> --query <query> --json",
    "similar_functions": "python3 knowledge/sources/tool_outputs/api/similar_functions.py --query <query> --json",
    "mismatch_patterns": "python3 knowledge/sources/tool_outputs/api/mismatch_patterns.py --query <query> --json"
  },
  "capabilities": [
    "tool_lookup",
    "similar_functions",
    "mismatch_patterns"
  ]
}
