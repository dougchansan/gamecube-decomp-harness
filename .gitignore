!projects/*/knowledge/tools/**/cache/.gitignore
!projects/*/knowledge/tools/**/cache/README.md
projects/*/knowledge/tools/**/indexes/*.json
projects/*/knowledge/tools/**/indexes/*.jsonl
projects/*/knowledge/tools/**/indexes/*.sqlite*

# Vendored debug toolchains (zig etc.) — hundreds of MB, fetched on demand.
toolpacks/gamecube-decomp/_impl/gamecube/mwcc_debug/tools/

projects/*/knowledge/tools/research/opseq/indexes/function_shapes.jsonl
projects/*/knowledge/tools/research/ghidra/indexes/symbol_lookup.jsonl

# Project-owned toolpack data. Bindings are tracked; generated shared data and
# per-worktree mutable caches are local/runtime artifacts.
projects/*/shared/tool-data/**/cache/**
projects/*/shared/tool-data/**/indexes/*.json
projects/*/shared/tool-data/**/indexes/*.jsonl
projects/*/shared/tool-data/**/indexes/*.sqlite*
projects/*/worktrees/
.DS_Store
__pycache__/
*.pyc

# Project workspaces: keep portable descriptors tracked, keep local runtime and
# checkout material ignored.
projects/*/checkout/
projects/*/state/
projects/*/graph/
projects/*/.pi-sessions/
projects/*/.pi-agent/
projects/*/local.env
projects/*/global.env
projects/*/local.project.json

