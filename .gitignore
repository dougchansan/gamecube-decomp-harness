# Legacy project-knowledge generated indexes; active sources use the sectioned
# paths below, but local caches may still exist at these older project paths.
projects/*/knowledge/sources/past_prs/data/current/
projects/*/knowledge/sources/past_prs/data/prs/runs/
projects/*/knowledge/sources/tool_outputs/indexes/tool_findings.jsonl
projects/*/knowledge/sources/external_mirrors/indexes/external_file_mentions.jsonl

# Project knowledge: keep portable corpora metadata/postmortems tracked, ignore
# bulk raw corpora, generated indexes, local graph DBs, and runner caches.
projects/*/knowledge/resource_graph/*.sqlite*
projects/*/knowledge/resource_graph/enrichments/*.jsonl
projects/*/knowledge/resource_graph/indexes/
projects/*/knowledge/sources/code_context/past_prs/data/current/
projects/*/knowledge/sources/code_context/past_prs/data/aggregate/
projects/*/knowledge/sources/code_context/past_prs/data/runs/
projects/*/knowledge/sources/code_context/past_prs/data/prs/runs/
projects/*/knowledge/sources/code_context/past_prs/data/prs/*/raw/
projects/*/knowledge/sources/code_context/past_prs/data/prs/*/extracted/
projects/*/knowledge/sources/**/data/library/index.csv
projects/*/knowledge/sources/**/data/library/index.jsonl
projects/*/knowledge/sources/**/data/library/known_fixes.md
projects/*/knowledge/sources/**/data/library/run_summary.json
projects/*/knowledge/sources/**/indexes/*.csv
projects/*/knowledge/sources/**/indexes/*.json
projects/*/knowledge/sources/**/indexes/*.jsonl
projects/*/knowledge/sources/**/indexes/*.sqlite*
projects/*/knowledge/sources/code_context/external_mirrors/indexes/external_file_mentions.jsonl
