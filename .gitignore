# code_context (moved knowledge sources): keep small metadata/postmortems
# tracked, ignore bulk corpora (raw diffs, extracted text, aggregates, runs).
knowledge/sources/code_context/past_prs/data/current/
knowledge/sources/code_context/past_prs/data/aggregate/
knowledge/sources/code_context/past_prs/data/runs/
knowledge/sources/code_context/past_prs/data/prs/runs/
knowledge/sources/code_context/past_prs/data/prs/*/raw/
knowledge/sources/code_context/past_prs/data/prs/*/extracted/
knowledge/sources/code_context/external_mirrors/indexes/external_file_mentions.jsonl
knowledge/sources/code_context/ssbm_data_sheet/indexes/cells.jsonl

# Vendored debug toolchains (zig etc.) — hundreds of MB, fetched on demand.
tools/_impl/melee/mwcc_debug/tools/

knowledge/tools/opseq/indexes/function_shapes.jsonl
knowledge/tools/ghidra/indexes/symbol_lookup.jsonl
.DS_Store
__pycache__/
*.pyc

# Project workspaces: keep portable descriptors tracked, keep local runtime and
# checkout material ignored.
projects/*/checkout/
projects/*/state/
projects/*/graph/
projects/*/.pi-sessions/
projects/*/.pi-agent/
projects/*/local.env
projects/*/global.env
projects/*/local.project.json

# Orchestrator runtime state (logs, per-run cycles, guardian output)
.decomp-orchestrator-state/runs/
.decomp-orchestrator-state/guardian/
.decomp-orchestrator-state/ui-processes/
.decomp-orchestrator-state/ui-server.log
.decomp-orchestrator-state/agent_state-shared.db
.decomp-orchestrator-state/*.sqlite-shm
.decomp-orchestrator-state/*.sqlite-wal

# Smoke fixtures intentionally mirror repo artifact names that the root
# .gitignore excludes for real generated outputs.
!testdata/
!testdata/smoke_repo/
!testdata/smoke_repo/objdiff.json
!testdata/smoke_repo/build/
!testdata/smoke_repo/build/GALE01/
!testdata/smoke_repo/build/GALE01/report.json
