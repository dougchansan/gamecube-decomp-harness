{
  "name": "colosseum-decomp-orchestrator",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/agent-kernel/packages/*"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "ui": "bun run ui:build && bun run ui:server",
    "ui:server": "bun apps/server/src/server.ts",
    "ui:dev": "bun run ui:build && sh -c 'bun run ui:watch & WATCH_PID=$!; trap \"kill $WATCH_PID 2>/dev/null\" EXIT; ORCH_UI_HOT_RELOAD=1 bun apps/server/src/server.ts'",
    "ui:dev:hot-server": "bun run ui:build && sh -c 'bun run ui:watch & WATCH_PID=$!; trap \"kill $WATCH_PID 2>/dev/null\" EXIT; ORCH_UI_HOT_RELOAD=1 bun --hot --no-clear-screen apps/server/src/server.ts'",
    "ui:build": "vite build --config apps/frontend/vite.config.ts",
    "ui:watch": "vite build --watch --config apps/frontend/vite.config.ts",
    "ui:check": "tsc --noEmit -p apps/frontend/tsconfig.json",
    "repo-policy:test": "bun test --max-concurrency=4 ./apps/server/src/core/tools/tooling-layout.test.ts ./apps/server/src/infrastructure/kernel/agent-kernel-boundaries.test.ts",
    "review-lint:test": "python3 -m pytest toolpacks/gamecube-decomp/source_editing/review_lint/tests",
    "check": "bun run repo-policy:test && bun run kg:test && tsc --noEmit && bun run ui:check && bun run review-lint:test",
    "smoke": "bun run --cwd apps/server smoke",
    "regression-check": "bun run server:job -- regression-check",
    "kg:sources": "bun run server:job -- kg-sources",
    "kg:test": "bun test apps/server/src/core/knowledge/graph/builders/legacy-colosseum-kg.test.ts",
    "kg:status": "bun run server:job -- kg-status",
    "kg:import-agent-state": "bun run server:job -- kg-import-agent-state",
    "kg:import-legacy-colosseum-kg": "bun run server:job -- kg-import-legacy-colosseum-kg",
    "kg:curate": "bun run server:job -- kg-curate",
    "kg:maintain": "bun run server:job -- kg-maintain",
    "kg:rebuild": "bun run server:job -- kg-rebuild-graph",
    "kg:search": "bun run server:job -- kg-search",
    "kg:smoke": "bun run server:job -- kg-smoke",
    "kg:file-card": "bun run server:job -- kg-file-card",
    "kg:rank-features": "bun run server:job -- kg-rank-features",
    "server:job": "bun apps/server/src/job-runner.ts"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.6",
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tokenizr": "^2.2.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "bun-types": "latest",
    "tailwindcss": "^4.3.0",
    "typescript": "latest",
    "vite": "^8.0.16"
  }
}
