{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "bun-types"
    ],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@agent-kernel/db": [
        "packages/agent-kernel/packages/db/src/index.ts"
      ],
      "@agent-kernel/db/*": [
        "packages/agent-kernel/packages/db/src/*"
      ],
      "@agent-kernel/kernel": [
        "packages/agent-kernel/packages/kernel/src/index.ts"
      ],
      "@agent-kernel/kernel/*": [
        "packages/agent-kernel/packages/kernel/src/*"
      ],
      "@agent-kernel/protocol": [
        "packages/agent-kernel/packages/protocol/src/index.ts"
      ],
      "@agent-kernel/tailer": [
        "packages/agent-kernel/packages/tailer/src/index.ts"
      ],
      "@agent-kernel/viewer-core": [
        "packages/agent-kernel/packages/viewer-core/src/index.ts"
      ],
      "@agent-kernel/viewer-shell": [
        "packages/agent-kernel/packages/viewer-shell/src/index.ts"
      ],
      "@agent-kernel/viewer-ui": [
        "packages/agent-kernel/packages/viewer-ui/src/index.ts"
      ],
      "@agent-kernel/viewer-ui/styles": [
        "packages/agent-kernel/packages/viewer-ui/src/trace-viewer/trace-viewer.css"
      ],
      "@codecaine-ai/prompt-kit": [
        "packages/agent-kernel/packages/prompt-kit/src/index.ts"
      ],
      "@codecaine-ai/prompt-kit/*": [
        "packages/agent-kernel/packages/prompt-kit/src/*"
      ],
      "@/*": [
        "apps/frontend/src/*"
      ],
      "@server/*": [
        "apps/server/src/*"
      ]
    },
    "jsx": "react-jsx"
  }
}
